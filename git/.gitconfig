[user]
	name = Raphaele Licciardo
	email = raphaele.licciardo@atruvia.de
[alias]
    client = !lazygit
[rebase]
	pull = true
[color]
	ui = always
[alias]

    # visual commit graph
    graph = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

    # show the recent history (n commits) 
    recent = "!f() { \
            n=${1:-10}; \
            git --no-pager log --pretty=format:'%h %cd %cn [%ae] %s' --date=relative -n \"$n\"; \
        }; f"

    # diff summary stats
    diffstat = !git --no-pager diff --shortstat

    # open lazygit UI
    client = !lazygit

