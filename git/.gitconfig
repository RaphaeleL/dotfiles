[user]
	name = Raphaele Licciardo
	email = raphaele.licciardo@atruvia.de
[alias]
    client = !lazygit
[rebase]
	pull = true
[color]
	ui = auto 
[alias]

    # show the recent n commits as a graph
    recent = "!f() { \
        n=${1:-10}; \
        git --no-pager log --graph --pretty=format:'%C(yellow)%h%Creset %C(white)%<(55,trunc)%s%Creset %C(blue)%<(18,trunc)%cn%Creset %C(green)%<(12,trunc)%cd%Creset' --date=relative -n \"$n\"; \
    }; f"

    timeline = "!f() { \
        n=${1:-10}; \
        git --no-pager log --decorate=short --graph --pretty=format:'%C(yellow)%h%Creset %C(white)%<(55,trunc)%s%Creset %C(blue)%<(18,trunc)%cn%Creset %C(green)%cd%Creset %C(auto)%d%Creset' --date=format:'%d %b %Y %H:%M' -n \"$n\"; \
    }; f"

    # diff summary stats
    diffstat = !git --no-pager diff --shortstat

    # open lazygit UI
    client = !lazygit

